"<!doctype html>\n<html>\n  <head>\n    <title>Osirion Fortnite Public API | Documentation</title>\n    <meta charset=\"utf-8\" />\n    <meta\n      name=\"viewport\"\n      content=\"width=device-width, initial-scale=1\" />\n  </head>\n  <body>\n    <div id=\"app\"></div>\n    <!-- Load the Script -->\n    <script src=\"https://cdn.jsdelivr.net/npm/@scalar/api-reference\"></script>\n\n    <!-- Initialize the Scalar API Reference -->\n    <script type=\"text/javascript\">\n      Scalar.createApiReference('#app', {\n        \"_integration\": \"express\",\n        \"url\": \"/openapi.json\",\n        \"favicon\": \"https://osirion.gg/favicon/favicon.svg\",\n        \"agent\": {\n          \"disabled\": true\n        },\n        \"showDeveloperTools\": \"never\",\n        \"tagsSorter\": \"alpha\",\n        \"theme\": \"purple\"})\n    </script>\n  </body>\n</html>"